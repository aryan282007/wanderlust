<% layout("listing/layout/boilerplate") %>
<body>
  <div class="row mt-3">
    <div class="col-8 offset-2">
<div class="card col-6 offset-3 show-card">
   <h3>Listing Details</h3>
  <img src="<%= listing.image.url %>" class="card-img-top  show-img" alt="image">
  <div class="card-body">
    <p class="card-text"><b><%= listing.title %></b> <br>
     <%= listing.description %> <br>
     &#8377; <%= listing.price.toLocaleString("en-IN") %> <br>
     <%= listing.location %> <br>
     <%= listing.country %>
    </p>
  </div>
</div>
</div>
  </div>

  
  <br>
<div class="btns">
  <a href="/allList/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-4 add-btn">edit</a>
  <br>
  <br>
  <form action="/allList/<%= listing._id %>?_method=delete" method="post" >
    <button class="btn btn-dark offset-7 ">delete </button>
    </div>
    <br>
  </form>
  
</body>
