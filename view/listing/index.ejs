<% layout("listing/layout/boilerplate") %>
<style>
#filter{
  display:flex;
  flex-wrap:wrap;
  align-items:center;
  gap:0.9rem;
  justify-content:center;
  padding: 0.8rem 0.2rem 1rem;
  margin-bottom: 1.5rem;
}
.filter{
  text-align:center;
  opacity:0.9;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  min-width:100px;
  padding:0.8rem 0.75rem;
  border-radius: 1.3rem;
  background: rgba(254,66,77,0.08);
  border: 1px solid transparent;
  transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
}
.filter:hover{
  opacity:1;
  cursor:pointer;
  transform: translateY(-3px);
  border-color: rgba(254,66,77,0.35);
  background: rgba(254,66,77,0.12);
}
.filter i{
  color:#fe424d;
  font-size:1.7rem;
  margin-bottom:0.35rem;
  width: 2.6rem;
  height: 2.6rem;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  border-radius:50%;
  background: rgba(255,255,255,0.9);
  box-shadow: 0 12px 24px rgba(0,0,0,0.05);
}
.filter p{
  font-size:0.85rem;
  margin-top:0.35rem;
  margin-bottom:0;
  text-transform: capitalize;
  color:#333;
}
.tax-info{
  display:inline;
  color:#777;
  margin-left:0.5rem;
}
.tax-toggle{
  border:1px solid rgba(34,34,34,0.15);
  border-radius:1.5rem;
  height:3.8rem;
  padding:0.65rem 1rem;
  display:flex;
  align-items:center;
  justify-content:center;
  flex:1 1 100%;
  margin-top:0.5rem;
  background: #fff;
  box-shadow: 0 18px 36px rgba(0,0,0,0.06);
}
.tax-toggle .form-check-label{
  margin-left: 0.7rem;
  font-weight: 600;
  color: #444;
}
@media (min-width: 992px) {
  #filter { justify-content:flex-start; }
  .tax-toggle { flex:0 0 auto; margin-left:auto; margin-top:0; }
}
.card-Link {
  text-decoration: none;
  color: inherit;
}
.card.pro{
  border-radius: 1.75rem;
  overflow: hidden;
  border: none !important;
  transition: transform 0.25s ease, box-shadow 0.25s ease;
  box-shadow: 0 24px 60px rgba(0,0,0,0.08);
}
.card.pro:hover{
  transform: translateY(-6px);
  box-shadow: 0 32px 70px rgba(0,0,0,0.12);
}
.card-img-top{
  border-radius: 1.75rem 1.75rem 0 0 !important;
  width: 100% !important;
  height: 23rem !important;
  object-fit: cover !important;
}
.card-body{
  padding: 1rem 1rem 1.2rem;
}
.card-text{
  margin-bottom: 0.55rem;
  color: #333;
}
.card-text:first-child{
  font-size: 1.05rem;
  font-weight: 700;
}
.price-text{
  font-size: 1.35rem !important;
  font-weight: 700 !important;
  color: #222 !important;
  margin-bottom: 0.35rem !important;
  line-height: 1.4;
}
.tax-per-night{
  font-size: 0.95rem;
  font-weight: 500;
  color: #666;
}
.card.pro .tax-info{
  display: block;
  font-size: 0.9rem;
  color: #b15454;
  font-style: normal;
  font-weight: 600;
  margin-top: 0.25rem;
}
.listing-img{ width: 100% !important; height: 23rem !important; object-fit: cover; }
@media (max-width: 767.98px){ .listing-img{ height: 16rem !important; } }
</style>
<body>
  <div id="filter" class="mt-2">
    <div class="filter">
      <i class="fa-solid fa-fire"></i>
      <p>Trending</p>
    </div>

    <div class="filter ">
      <i class="fa-solid fa-bed"></i>
      <p>Rooms</p>
    </div>

    <div class="filter ">
      <i class="fa-solid fa-city"></i>
      <p>city</p>
    </div>

    <div class="filter ">
      <i class="fa-solid fa-mountain"></i>
      <p>mountain</p>
    </div>

    <div class="filter ">
      <i class="fa-solid fa-building"></i>
      <p>Castles</p>
    </div>

     <div class="filter ">
      <i class="fa-solid fa-person-swimming"></i>
      <p>Beach</p>
    </div>

     <div class="filter ">
      <i class="fa-solid fa-campground"></i>
      <p>Camping</p>
    </div>

    <div class="filter ">
     <i class="fa-solid fa-seedling"></i>
      <p>Farmes</p>
    </div>

     <div class="filter ">
      <i class="fa-solid fa-mountain-city"></i>
      <p>town</p>
    </div>

    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after tax</label>
     </div>
    </div>
  </div>
  <!-- <h3>ALL LISTINGS</h3> -->
  <!-- <form action="/listing/new" method="get">
    <button>Create new post!</button>
  </form>
<br> -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">

 <% for(let List of allListing){ %>
  <a href="/listings/<%= List._id %>" class="card-Link">
<div class="card pro mt-3" >
  <img src="<%= List.image.url %>" class="card-img-top listing-img" alt="Listing">
   <div class="card-img-overlay"></div>
  <div class="card-body">
    <b><p class="card-text card-title-text"><%= List.title %></p></b>
    <p class="card-text price-text">&#8377; <%= List.price.toLocaleString("en-IN")  %> <span class="tax-per-night">/ night</span>
    <br><i class="tax-info">+18% GST</i>
    </p>
  </div>
</div>
</a>
<% } %>

 </div>
 

 <script>
  const taxToggle = document.getElementById("switchCheckDefault");
  let taxInfoElements = document.querySelectorAll(".tax-info");
  taxToggle.addEventListener("change", function() {
    const cards = document.querySelectorAll(".card-body");
    cards.forEach(card => {
      const priceElement = card.querySelector(".card-text:nth-child(2)");
      const priceText = priceElement.textContent;
      const priceMatch = priceText.match(/₹\s?([\d,]+)/);
      if (priceMatch) {
        let price = parseInt(priceMatch[1].replace(/,/g, ''));
        if (this.checked) {
          price += Math.round(price * 0.18); // Add 18% tax
        } else {
          price = Math.round(price / 1.18); // Remove tax
        }
        priceElement.textContent = `₹ ${price.toLocaleString("en-IN")} / night`;
      }
    });
  });
 </script>
</body>
