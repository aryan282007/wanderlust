<% layout("listing/layout/boilerplate") %>
<body>
  <div class="row">
    <div class="col-8 offset-2">
 <h3>entre details</h3>
 <br>
 <form action="/listing" method= "post">
  <div class="mb-3">
  <label for="title" class="form-label">title</label>
  <input type="text" name="listing[title]" placeholder="entre the title" class="form-control">
  </div>
  <div class="mb-3">
    <label for="description"class="form-lebal" >description</label>
  <textarea name="listing[description]" placeholder="entre the description" class="form-control"></textarea>
  </div>
  <div class="mb-3">
   <label for="image"class="form-label" >image url</label>
  <input type="text" name="listing[image.url]" placeholder=" image url" class="form-control">
  </div>
  <div class="row">
  <div class="mb-3 col-md-4">
    <label for="price"class="form-lable">price</label>
  <input type="number" name="listing[price]" placeholder="Ex-1200"class="form-control">
  </div>
  <div class="mb-3 col-md-8">
    <label for="country" class="form-label">country</label>
  <input type="text" name="listing[country]" placeholder="Ex-india" class="form-control">
  </div>
  </div>
  <div class="mb-3">
    <label for="location" class="form-label">Location</label>
  <input type="text" class="form-control" name="listing[location]" placeholder="Ex-jaipur">
  </div>
  <br>
  <button  class="btn btn-dark add-btn" >add</button>
  <br>
  <br>
 </form>
</body>
</div>
</div>